{
  "name": "cinescope",
  "version": "1.0.0",
  "description": "A Root package.json file to run both backend and frontend concurrently",
  "keywords": [
    "Movies",
    "cinema",
    "webseries"
  ],
  "homepage": "https://github.com/Arslan950/CineScope#readme",
  "bugs": {
    "url": "https://github.com/Arslan950/CineScope/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Arslan950/CineScope.git"
  },
  "license": "ISC",
  "author": "",
  "type": "commonjs",
  "main": "index.js",
  "scripts": {
    "dev:backend": "npm run dev --prefix backend",
    "dev:frontend": "npm run dev --prefix frontend",
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\""
  },
  "dependencies": {
    "concurrently": "^10.0.3"
  }
}